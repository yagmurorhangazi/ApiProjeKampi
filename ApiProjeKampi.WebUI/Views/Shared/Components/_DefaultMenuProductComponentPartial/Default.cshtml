@model List<ApiProjeKampi.WebUI.Dtos.ProductDtos.ResultProductDto>

<div class="tab-content" data-aos="fade-up" data-aos-delay="200">

    <div class="tab-pane fade active show" id="menu-starters">

        <div class="tab-header text-center">
            <p>Menü</p>
            <h3>Tüm Lezzetler</h3>
        </div>

        <div class="row gy-5">

            @* KORUMA DUVARI: Arka plandan veri boş (null) gelmediyse döngüyü çalıştır *@
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="col-lg-4 menu-item">
                        <a href="@item.ImageUrl" class="glightbox">
                            <img src="@item.ImageUrl" class="menu-img img-fluid" alt="@item.ProductName">
                        </a>
                        <h4>@item.ProductName</h4>
                        <p class="ingredients">
                            @item.Description
                        </p>
                        <p class="price">
                            @item.Price ₺
                        </p>
                    </div>
                }
            }
            else
            {
                @* Veriler gelmezse tasarım patlamasın diye ekranda çıkacak kibar uyarı *@
                <div class="col-12 text-center">
                    <div class="alert alert-info" role="alert">
                        Şu anda menü öğeleri yüklenemedi. Lütfen API'nin /api/Products endpoint'ini ve port numarasını kontrol edin.
                    </div>
                </div>
            }

        </div>
    </div>
</div>