@model List<ApiProjeKampi.WebUI.Dtos.CategoryDtos.ResultCategoryDto>

<ul class="nav nav-tabs d-flex justify-content-center" data-aos="fade-up" data-aos-delay="100">

    <li class="nav-item">
        <a class="nav-link active show" data-bs-toggle="tab" data-bs-target="#menu-all">
            <h4>Tüm Menü</h4>
        </a>
    </li>@* KORUMA DUVARI: Model boş değilse kategorileri listele *@
    @if (Model != null && Model.Any())
    {
        @foreach (var item in Model)
        {
            <li class="nav-item">
                @* DÜZELTME: data-bs-target kısmını her kategorinin kendi ID'sine göre benzersiz yaptık. 
                   Böylece tıklanan kategorinin alt menüsü doğru açılacak.
                *@
                <a class="nav-link" data-bs-toggle="tab" data-bs-target="#menu-@item.CategoryId">
                    <h4>@item.CategoryName</h4>
                </a>
            </li>
        }
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link disabled">
                <h4>Kategoriler Yüklenemedi</h4>
            </a>
        </li>
    }

</ul>